# API
OPENAI_API_KEY=replace-me
OPENAI_MODEL=gpt-4.1-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
API_HOST=0.0.0.0
API_PORT=8000
AUTO_CREATE_SCHEMA=false

# Core storage
POSTGRES_DSN=postgresql+asyncpg://personabot:personabot@localhost:5432/personabot
REDIS_URL=redis://localhost:6379/0
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=persona_memories
QDRANT_VECTOR_SIZE=1536
MEMORY_TOP_K=5
MEMORY_CANDIDATE_MULTIPLIER=4
MEMORY_SEMANTIC_WEIGHT=0.62
MEMORY_IMPORTANCE_WEIGHT=0.25
MEMORY_RECENCY_WEIGHT=0.13
MEMORY_RECENCY_HALF_LIFE_HOURS=72
DEFAULT_PERSONA_ID=balanced
CORS_ORIGINS=http://localhost:3000,http://localhost:3001,http://127.0.0.1:3000,http://127.0.0.1:3001

# Frontend
NEXT_PUBLIC_API_WS_URL=ws://localhost:8000/ws/chat
NEXT_PUBLIC_API_HTTP_URL=http://localhost:8000
